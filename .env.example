# Server
PORT=3000
HOST=localhost

# Xenova/transformers local embeddings
XENOVA_EMBEDDINGS_MODEL=Xenova/all-MiniLM-L6-v2

# OpenAI Codex endpoints
CODEX_CHAT_URL=https://chatgpt.com/backend-api/codex/responses
CODEX_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
CODEX_TOKEN_URL=https://auth.openai.com/oauth/token
CODEX_REDIRECT_URI=http://localhost:1455/auth/callback

# OpenAI Codex OAuth credentials
# Obtain these by completing the OAuth PKCE flow via /auth (oauth.mjs)
CODEX_ACCESS_TOKEN=
CODEX_REFRESH_TOKEN=
CODEX_EXPIRES_AT=
CODEX_ACCOUNT_ID=

# Claude Code OAuth endpoints
CLAUDE_AUTHORIZE_URL=https://claude.ai/oauth/authorize
CLAUDE_TOKEN_URL=https://console.anthropic.com/v1/oauth/token
CLAUDE_REDIRECT_URI=https://console.anthropic.com/oauth/code/callback

# Claude Code OAuth credentials
# Obtain these by running: npm run auth:claude
CLAUDE_ACCESS_TOKEN=
CLAUDE_REFRESH_TOKEN=
CLAUDE_EXPIRES_AT=
